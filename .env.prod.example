# Pi production runtime secrets — copy to .env.prod and fill in values.
# .env.prod is gitignored and must never be committed.

# AI services (server-side only — never baked into the Docker image)
CHAINGPT_API_KEY=
DEEPSEEK_API_KEY=

# Gasless faucet sender wallet (deployer key)
SENDER_PRIVATE_KEY=

# Optional: write structured JSON logs to a file (matches docker-compose volume)
# NOX_LOG_FILE=/app/logs/nox.log

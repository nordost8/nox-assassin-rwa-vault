# Server-only AI keys (runtime only — never baked into Docker image)
CHAINGPT_API_KEY=
DEEPSEEK_API_KEY=

# Optional: write structured JSON logs to file (in addition to stdout / docker logs)
# NOX_LOG_FILE=/app/logs/nox.log

# WalletConnect / Reown Cloud (https://dashboard.reown.com). Provide either variable name:
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
# NEXT_PUBLIC_PROJECT_ID=

# Target network (Arbitrum Sepolia)
NEXT_PUBLIC_CHAIN_ID=421614
NEXT_PUBLIC_RPC_URL=

# Demo deployments (Arbitrum Sepolia)
# Set these after running `npm run deploy:demo`
NEXT_PUBLIC_DEMO_ASSET_ADDRESS=
NEXT_PUBLIC_DEMO_CONFIDENTIAL_WRAPPER_ADDRESS=
NEXT_PUBLIC_DEMO_FAUCET_ADDRESS=

# Confidential Vault contract (set after running `npm run deploy:vault`)
NEXT_PUBLIC_VAULT_CONTRACT_ADDRESS=

# Server-side wallet for gasless faucet (deployer private key — never expose publicly)
# SENDER_PRIVATE_KEY=
